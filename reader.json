{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "storageAccountName": {
      "type": "string",
      "metadata": { "description": "Existing storage account in the client's subscription" }
    },
    "isvPrincipalId": {
      "type": "string",
      "metadata": { "description": "Object (principal) ID of the ISV's user-assigned managed identity" }
    },
    "roleDefinitionId": {
      "type": "string",
      "defaultValue": "ba92f5b4-2d11-453d-a403-e96b0029c9fe",
      "metadata": { "description": "Built-in role: Storage Blob Data Contributor" }
    }
  },
  "variables": {
    "roleAssignmentName": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), parameters('isvPrincipalId'), parameters('roleDefinitionId'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[concat(parameters('storageAccountName'), '/Microsoft.Authorization/', variables('roleAssignmentName'))]",
      "properties": {
        "roleDefinitionId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Authorization/roleDefinitions/', parameters('roleDefinitionId'))]",
        "principalId": "[parameters('isvPrincipalId')]",
        "principalType": "ServicePrincipal"
      }
    }
  ]
}
